---
import { marques } from "../data/site";
const list = [...marques, ...marques];
---

<div class="marquee relative overflow-hidden border-y border-gold/12 bg-ink-900 py-6">
  <div class="marquee-track">
    {
      list.map((m) => (
        <span class="flex items-center">
          <span class="font-display text-xl text-mist/70 px-7 tracking-wide whitespace-nowrap">
            {m}
          </span>
          <span class="h-1 w-1 rotate-45 bg-gold/40" />
        </span>
      ))
    }
  </div>
  <!-- edge fades -->
  <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-ink-900 to-transparent"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-ink-900 to-transparent"></div>
</div>
