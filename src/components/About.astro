---
import { company, team } from "../data/site";
import { getLang, getDict } from "../i18n";

interface Props {
  bare?: boolean;
}
const { bare = false } = Astro.props;
const lang = getLang(Astro);
const t = getDict(lang);

const roles = [t.roles.founder, t.roles.md];
const p1 = t.about.p1.replace("{year}", String(company.founded)).replace("{city}", company.address.city);
const p2Parts = t.about.p2.split("{partner}");
---

<section id="about" class="relative overflow-hidden bg-ink-900 py-24 sm:py-32">
  <div class="mx-auto max-w-[1500px] px-5 sm:px-8 lg:px-12">
    <div class="grid items-center gap-14 lg:grid-cols-2 lg:gap-20">
      <!-- Image -->
      <div class="relative" data-reveal="clip">
        <div class="aspect-[4/5] overflow-hidden border border-white/8">
          <img src="/gallery/1.jpeg" alt="Hollmann International" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <div class="absolute -bottom-6 -end-2 hidden border border-gold/30 bg-ink/85 px-7 py-5 backdrop-blur-sm sm:block">
          <div class="font-display text-4xl text-gold-bright">15+</div>
          <div class="mt-1 text-[0.66rem] tracking-[0.2em] text-mist uppercase">{t.about.years}</div>
        </div>
      </div>

      <!-- Text -->
      <div>
        {
          !bare && (
            <Fragment>
              <p class="eyebrow flex items-center gap-3" data-reveal>
                <span class="inline-block h-px w-8 bg-gold" />
                {t.about.eyebrow}
              </p>
              <h2 class="display-lg mt-5 text-cream" data-reveal style="--reveal-delay:100ms">
                {t.about.title}
              </h2>
            </Fragment>
          )
        }
        <div class="mt-6 space-y-5 text-lg leading-relaxed text-mist" data-reveal style="--reveal-delay:180ms">
          <p>{p1}</p>
          <p>
            {p2Parts[0]}<a href={company.partner.url} class="text-gold-bright underline-offset-4 hover:underline">{company.partner.name}</a>{p2Parts[1]}
          </p>
        </div>

        <div class="mt-10 grid grid-cols-2 gap-6" data-reveal style="--reveal-delay:240ms">
          {
            team.map((m, i) => (
              <div class="border-s border-gold/30 ps-4">
                <div class="font-display text-xl text-cream">{m.name}</div>
                <div class="mt-1 text-[0.7rem] tracking-[0.14em] text-fog uppercase">{roles[i]}</div>
              </div>
            ))
          }
        </div>

        <div class="mt-10 border-t border-white/8 pt-7" data-reveal style="--reveal-delay:300ms">
          <p class="text-[0.7rem] tracking-[0.22em] text-fog uppercase">{t.about.servedIn}</p>
          <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2">
            {t.langNames.map((l: string) => <span class="text-mist transition-colors duration-300 hover:text-gold-bright">{l}</span>)}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
