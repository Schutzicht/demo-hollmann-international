---
import { company } from "../data/site";
import { getLang, getDict } from "../i18n";

const lang = getLang(Astro);
const t = getDict(lang);
---

<!-- ============ Compare bar ============ -->
<div
  data-compare-bar
  class="fixed bottom-5 left-1/2 z-[100] flex -translate-x-1/2 translate-y-[140%] items-center gap-4 border border-gold/30 bg-ink-850/95 px-5 py-3 backdrop-blur-xl transition-transform duration-500"
  style="transition-timing-function: var(--ease-lux)"
>
  <span class="hidden text-[0.66rem] tracking-[0.18em] text-fog uppercase sm:block">
    {t.compare.title} (<span data-compare-count>0</span>)
  </span>
  <div data-compare-thumbs class="flex gap-2"></div>
  <button data-open-compare class="btn btn-gold !px-5 !py-2.5 !text-[0.7rem]">{t.cta.compare}</button>
  <button data-clear-compare aria-label="Clear" class="text-fog transition-colors hover:text-cream">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
</div>

<!-- ============ Compare modal ============ -->
<div data-compare-modal class="pointer-events-none fixed inset-0 z-[120] flex items-center justify-center p-4 opacity-0 transition-opacity duration-400">
  <div data-close-compare class="absolute inset-0 bg-ink/85 backdrop-blur-md"></div>
  <div data-modal-panel class="relative max-h-[88vh] w-full max-w-5xl translate-y-6 overflow-y-auto border border-white/10 bg-ink-900 p-7 transition-transform duration-500 sm:p-9" style="transition-timing-function: var(--ease-lux)">
    <div class="flex items-center justify-between">
      <h3 class="font-display text-3xl text-cream">{t.compare.title}</h3>
      <button data-close-compare aria-label="Close" class="text-mist transition-colors hover:text-gold-bright">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div data-compare-body class="mt-7"></div>
  </div>
</div>

<!-- ============ Shortlist drawer ============ -->
<div data-shortlist-backdrop class="pointer-events-none fixed inset-0 z-[105] bg-ink/70 opacity-0 backdrop-blur-sm transition-opacity duration-500"></div>
<aside data-shortlist class="fixed right-0 top-0 z-[110] flex h-full w-full max-w-md translate-x-full flex-col border-l border-white/10 bg-ink-900 transition-transform duration-500" style="transition-timing-function: var(--ease-lux)">
  <div class="flex items-center justify-between border-b border-white/8 px-7 py-6">
    <h3 class="font-display text-2xl text-cream">{t.shortlist.title}</h3>
    <button data-close-shortlist aria-label="Close" class="text-mist transition-colors hover:text-gold-bright">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <div class="flex-1 overflow-y-auto px-7 py-6">
    <p data-shortlist-empty class="text-mist">{t.shortlist.empty}</p>
    <div data-shortlist-items class="space-y-5"></div>
  </div>
  <div class="border-t border-white/8 px-7 py-6">
    <button data-enquire="" class="btn btn-gold w-full">{t.shortlist.enquireBtn}</button>
    <p class="mt-3 text-center text-[0.66rem] text-fog">{t.shortlist.note}</p>
  </div>
</aside>

<!-- ============ Enquiry modal ============ -->
<div data-enquiry-modal class="pointer-events-none fixed inset-0 z-[120] flex items-center justify-center p-4 opacity-0 transition-opacity duration-400">
  <div data-close-enquiry class="absolute inset-0 bg-ink/85 backdrop-blur-md"></div>
  <div data-modal-panel class="relative max-h-[90vh] w-full max-w-lg translate-y-6 overflow-y-auto border border-white/10 bg-ink-900 p-7 transition-transform duration-500 sm:p-9" style="transition-timing-function: var(--ease-lux)">
    <div class="flex items-start justify-between">
      <div>
        <p class="eyebrow">{t.enquiry.eyebrow}</p>
        <h3 class="font-display mt-2 text-3xl text-cream">{t.enquiry.title}</h3>
      </div>
      <button data-close-enquiry aria-label="Close" class="text-mist transition-colors hover:text-gold-bright">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <div data-enquiry-context class="mt-6 hidden"></div>

    <form data-form class="mt-6 space-y-4">
      <input type="hidden" name="subject" data-enquiry-subject value="" />
      <div class="grid gap-4 sm:grid-cols-2">
        <input required name="name" type="text" placeholder={t.contact.namePh} class="w-full border border-white/12 bg-ink-850 px-4 py-3 text-cream outline-none transition-colors placeholder:text-fog focus:border-gold" />
        <input required name="email" type="email" placeholder={t.contact.emailPh} class="w-full border border-white/12 bg-ink-850 px-4 py-3 text-cream outline-none transition-colors placeholder:text-fog focus:border-gold" />
      </div>
      <input name="phone" type="tel" placeholder={t.contact.phonePh} class="w-full border border-white/12 bg-ink-850 px-4 py-3 text-cream outline-none transition-colors placeholder:text-fog focus:border-gold" />
      <textarea name="message" rows="3" placeholder={t.contact.messagePh} class="w-full resize-none border border-white/12 bg-ink-850 px-4 py-3 text-cream outline-none transition-colors placeholder:text-fog focus:border-gold"></textarea>
      <button type="submit" class="btn btn-gold w-full">{t.cta.send}</button>
      <p data-success class="hidden text-sm text-gold-bright">{t.contact.success}</p>
    </form>

    <div class="mt-6 flex flex-col gap-3 border-t border-white/8 pt-6 sm:flex-row">
      <a data-enquiry-wa href="https://wa.me/4942180608210" target="_blank" rel="noopener" class="btn btn-ghost flex-1 !px-4">WhatsApp</a>
      <a href={`tel:${company.phoneHref}`} class="btn btn-ghost flex-1 !px-4">{t.cta.call} {company.phone}</a>
    </div>
  </div>
</div>

<!-- ============ Lightbox ============ -->
<div data-lightbox class="pointer-events-none fixed inset-0 z-[130] flex items-center justify-center opacity-0 transition-opacity duration-400">
  <div data-lightbox-backdrop class="absolute inset-0 bg-ink/95"></div>
  <button data-lightbox-close aria-label="Close" class="absolute end-5 top-5 z-10 text-cream transition-colors hover:text-gold-bright">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
  <button data-lightbox-prev aria-label="Previous" class="absolute left-3 z-10 flex h-12 w-12 items-center justify-center text-cream transition-colors hover:text-gold-bright sm:left-8">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M15 18l-6-6 6-6"/></svg>
  </button>
  <button data-lightbox-next aria-label="Next" class="absolute right-3 z-10 flex h-12 w-12 items-center justify-center text-cream transition-colors hover:text-gold-bright sm:right-8">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M9 6l6 6-6 6"/></svg>
  </button>
  <img data-lightbox-img src="" alt="" class="relative max-h-[86vh] max-w-[90vw] object-contain" />
  <div data-lightbox-counter class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[0.72rem] tracking-[0.2em] text-mist"></div>
</div>
