---
// First-visit intro: gold wordmark reveal, then a curtain lift to the hero
---

<div data-preloader class="preloader">
  <div class="preloader-inner">
    <div class="flex flex-col items-center leading-none">
      <span class="preloader-word font-display text-4xl tracking-[0.3em] text-cream sm:text-6xl">
        HOLLMANN
      </span>
      <span class="preloader-sub mt-2 text-[0.6rem] tracking-[0.6em] text-gold sm:text-xs">
        INTERNATIONAL
      </span>
    </div>
    <div class="preloader-line"></div>
  </div>
</div>
