---
import { services, individualization } from "../data/site";

const icons: Record<string, string> = {
  "Worldwide delivery": `<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.6 2.5 15.4 0 18M12 3c-2.5 2.6-2.5 15.4 0 18"/>`,
  "Sourcing & procurement": `<circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>`,
  "Bespoke individualization": `<path d="M12 3l2.5 5.5L20 9l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5L12 3z"/>`,
  "Trade-in & consignment": `<path d="M7 7h11M18 7l-3-3M18 7l-3 3M17 17H6M6 17l3-3M6 17l3 3"/>`,
  "Financing & leasing": `<rect x="3" y="6" width="18" height="12" rx="2"/><path d="M3 10h18M7 14h4"/>`,
  "Inspection & warranty": `<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/><path d="m9 12 2 2 4-4"/>`,
};
---

<section id="service" class="bg-ink py-24 sm:py-32">
  <div class="mx-auto max-w-[1500px] px-5 sm:px-8 lg:px-12">
    <div class="grid gap-14 lg:grid-cols-[0.9fr_1.1fr] lg:gap-20">
      <!-- Intro -->
      <div class="lg:sticky lg:top-28 lg:self-start">
        <p class="eyebrow flex items-center gap-3" data-reveal>
          <span class="inline-block h-px w-8 bg-gold"></span>
          Service
        </p>
        <h2 class="display-lg mt-5 text-cream" data-reveal style="--reveal-delay:100ms">
          More than a sale. A standard.
        </h2>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-mist" data-reveal style="--reveal-delay:200ms">
          From the first call to delivery at your door, every detail is managed
          in-house by specialists who live for these cars.
        </p>

        <!-- Individualization feature -->
        <div class="mt-10 border border-white/8 bg-ink-850 p-7" data-reveal style="--reveal-delay:280ms">
          <h3 class="font-display text-2xl text-cream">Bespoke individualization</h3>
          <ul class="mt-5 space-y-3">
            {
              individualization.map((item) => (
                <li class="flex items-start gap-3 text-sm text-mist">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rotate-45 bg-gold"></span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Service grid -->
      <div class="grid gap-px overflow-hidden border border-white/8 bg-white/8 sm:grid-cols-2">
        {
          services.map((s, i) => (
            <div
              class="group flex flex-col bg-ink p-7 transition-colors duration-500 hover:bg-ink-850"
              data-reveal
              style={`--reveal-delay:${(i % 2) * 90}ms`}
            >
              <span class="text-gold transition-transform duration-500 group-hover:-translate-y-1">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.title]} />
              </span>
              <h3 class="font-display mt-6 text-xl text-cream">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-mist">{s.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
