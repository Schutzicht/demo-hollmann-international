---
import VehicleDetailView from "../../components/views/VehicleDetailView.astro";
import { vehicles, vehicleSlug } from "../../data/site";

export function getStaticPaths() {
  return vehicles.map((v) => ({
    params: { slug: vehicleSlug(v) },
    props: { vehicle: v },
  }));
}

const { vehicle } = Astro.props;
---

<VehicleDetailView vehicle={vehicle} />
