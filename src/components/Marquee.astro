---
import { marques } from "../data/site";

const logos = marques.map((m) => ({
  name: m,
  src: `/brands/${m.toLowerCase().replace(/ /g, "-")}.svg`,
}));
const list = [...logos, ...logos];
---

<div class="marquee relative overflow-hidden border-y border-gold/12 bg-ink-900 py-9">
  <div class="marquee-track items-center">
    {
      list.map((l) => (
        <span class="flex shrink-0 items-center justify-center px-8 sm:px-10">
          <img
            src={l.src}
            alt={l.name}
            title={l.name}
            class="h-9 w-auto max-w-[120px] opacity-55 transition-opacity duration-500 hover:opacity-100 sm:h-10"
            loading="lazy"
            decoding="async"
          />
        </span>
      ))
    }
  </div>
  <!-- edge fades -->
  <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-ink-900 to-transparent"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-ink-900 to-transparent"></div>
</div>
