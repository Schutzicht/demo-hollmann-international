---
import Base from "../../layouts/Base.astro";
import Header from "../Header.astro";
import Footer from "../Footer.astro";
import VehicleCard from "../VehicleCard.astro";
import { vehicles, carImages, fmtEUR, vehicleSlug, vehicleTitle, company, type Vehicle } from "../../data/site";
import { getLang, getDict } from "../../i18n";

interface Props { vehicle: Vehicle }
const { vehicle: v } = Astro.props;
const lang = getLang(Astro);
const t = getDict(lang);
const base = lang === "en" ? "" : `/${lang}`;
const title = vehicleTitle(v);
const tagline = (t.taglines as any)[v.id] ?? v.tagline;
const images = carImages(v);
const imgList = images.join(",");

const tDrive = (s: string) => (t.drivetrain as any)[s] ?? s;
const tVal = (s: string) => {
  if (s === "Delivery mileage") return t.values.deliveryMileage;
  if (s === "On request") return t.values.onRequest;
  if (s === "Plug-in Hybrid") return (t.drivetrain as any)["Plug-in Hybrid"];
  return s;
};

const related = vehicles.filter((x) => x.id !== v.id && x.categories.some((c) => v.categories.includes(c))).slice(0, 3);
const relatedFinal = related.length ? related : vehicles.filter((x) => x.id !== v.id).slice(0, 3);

const L = t.detail.labels;
const specs = [
  { label: L.year, value: String(v.year) },
  { label: L.drivetrain, value: tDrive(v.drivetrain) },
  { label: L.engine, value: v.engine },
  { label: L.power, value: v.power },
  { label: L.accel, value: v.accel },
  { label: L.topSpeed, value: v.topSpeed },
  { label: L.transmission, value: v.transmission },
  { label: L.mileage, value: tVal(v.mileage) },
  { label: L.exterior, value: v.colorExt },
  { label: L.interior, value: v.colorInt },
  { label: L.consumption, value: tVal(v.consumption) },
  { label: L.co2, value: tVal(v.co2) },
  { label: L.co2class, value: v.co2class },
];
---

<Base title={`${title} · ${company.full}`} description={tagline}>
  <Header />
  <main class="bg-ink pt-28 sm:pt-32">
    <div class="mx-auto max-w-[1500px] px-5 sm:px-8 lg:px-12">
      <a href={`${base}/collection`} class="inline-flex items-center gap-2 text-[0.72rem] tracking-[0.16em] text-fog uppercase transition-colors hover:text-gold-bright">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="rtl:-scale-x-100"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
        {t.cta.backToCollection}
      </a>

      <div class="mt-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-[0.72rem] tracking-[0.24em] text-gold uppercase">{v.brand}</p>
          <h1 class="display-lg mt-2 text-cream">{v.model}{v.variant && <span class="text-mist"> {v.variant}</span>}</h1>
          <p class="mt-3 max-w-xl text-mist">{tagline}</p>
        </div>
        {v.badge && <span class="self-start border border-gold/40 px-4 py-2 text-[0.66rem] tracking-[0.18em] text-gold-bright uppercase lg:self-end">{v.badge}</span>}
      </div>

      <div class="mt-10 grid gap-10 lg:grid-cols-[1.45fr_0.55fr]">
        <!-- Gallery -->
        <div>
          <div data-rotate={imgList} class="group relative aspect-[3/2] cursor-grab touch-pan-y overflow-hidden border border-white/8 bg-ink-900 select-none">
            <img data-main src={images[0]} alt={title} class="h-full w-full object-cover" transition:name={`car-${v.id}`} />
            <div class="pointer-events-none absolute bottom-3 start-3 flex items-center gap-2 border border-white/15 bg-ink/55 px-3 py-1.5 text-[0.6rem] tracking-[0.18em] text-cream/80 uppercase backdrop-blur-sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5"/></svg>
              {t.detail.dragToRotate}
            </div>
            <button data-open-lightbox data-images={imgList} data-index="0" aria-label={t.detail.openGallery} class="absolute end-3 top-3 flex h-10 w-10 items-center justify-center border border-white/15 bg-ink/55 text-cream backdrop-blur-sm transition-all duration-300 hover:border-gold hover:text-gold-bright">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
            </button>
          </div>
          <div class="mt-3 grid grid-cols-5 gap-3">
            {images.map((src, i) => (
              <button data-thumb={src} class:list={["aspect-[3/2] overflow-hidden border transition-all duration-300", i === 0 ? "border-gold" : "border-white/8 hover:border-gold/50"]} aria-label={`Image ${i + 1}`}>
                <img src={src} alt="" class="h-full w-full object-cover" loading="lazy" />
              </button>
            ))}
          </div>
        </div>

        <!-- Summary -->
        <aside class="lg:sticky lg:top-28 lg:self-start">
          <div class="border border-white/8 bg-ink-850 p-7">
            <div class="font-display text-4xl text-gold-bright" data-price={v.priceNet}>{fmtEUR(v.priceNet)}</div>
            <div class="mt-1 flex flex-wrap items-center gap-x-2 text-[0.7rem] tracking-[0.12em] text-fog">
              {v.priceGross ? (
                <>
                  <span>{t.detail.netExport}</span><span>·</span>
                  <span>{t.detail.gross} <span data-price={v.priceGross}>{fmtEUR(v.priceGross)}</span></span>
                </>
              ) : (<span>{t.values.vatNote}</span>)}
            </div>

            <div class="mt-6 grid grid-cols-2 gap-px overflow-hidden border border-white/8 bg-white/8">
              <div class="bg-ink-850 p-4"><div class="text-sm text-cream">{v.power}</div><div class="mt-1 text-[0.58rem] tracking-[0.14em] text-fog uppercase">{L.power}</div></div>
              <div class="bg-ink-850 p-4"><div class="text-sm text-cream">{v.accel}</div><div class="mt-1 text-[0.58rem] tracking-[0.14em] text-fog uppercase">{t.card.accelKm}</div></div>
              <div class="bg-ink-850 p-4"><div class="text-sm text-cream">{v.topSpeed}</div><div class="mt-1 text-[0.58rem] tracking-[0.14em] text-fog uppercase">{L.topSpeed}</div></div>
              <div class="bg-ink-850 p-4"><div class="text-sm text-cream">{v.year}</div><div class="mt-1 text-[0.58rem] tracking-[0.14em] text-fog uppercase">{L.year}</div></div>
            </div>

            <div class="mt-6 flex flex-col gap-3">
              <button data-enquire={v.id} data-magnetic class="btn btn-gold w-full">{t.cta.enquireCar}</button>
              <div class="grid grid-cols-2 gap-3">
                <button data-fav={v.id} class="flex items-center justify-center gap-2 border border-white/12 py-3 text-[0.7rem] tracking-[0.14em] text-mist uppercase transition-all duration-300 hover:border-gold/50 hover:text-gold-bright">
                  <svg width="15" height="15" viewBox="0 0 24 24" stroke-width="1.5"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
                  {t.cta.save}
                </button>
                <button data-compare={v.id} class="flex items-center justify-center gap-2 border border-white/12 py-3 text-[0.7rem] tracking-[0.14em] text-mist uppercase transition-all duration-300 hover:border-gold/50 hover:text-gold-bright">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6h7v12H3zM14 6h7v12h-7z"/></svg>
                  {t.cta.compare}
                </button>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <a href="https://wa.me/4942180608210" target="_blank" rel="noopener" class="btn btn-ghost w-full !px-4">WhatsApp</a>
                <a href={`tel:${company.phoneHref}`} class="btn btn-ghost w-full !px-4">{t.cta.call}</a>
              </div>
            </div>

            <div class="mt-7 border-t border-white/8 pt-6">
              <div class="text-[0.68rem] tracking-[0.2em] text-fog uppercase">{t.detail.financeEstimate}</div>
              <div class="mt-4 space-y-4" data-finance data-finance-price={v.priceNet}>
                <label class="block">
                  <div class="flex justify-between text-xs text-mist"><span>{t.detail.downPayment}</span><span data-deposit-out></span></div>
                  <input data-deposit type="range" min="0" max="60" value="20" class="mt-2 w-full accent-[var(--color-gold)]" />
                </label>
                <label class="block">
                  <span class="text-xs text-mist">{t.detail.term}</span>
                  <select data-term class="mt-2 w-full border border-white/12 bg-ink px-3 py-2.5 text-sm text-cream outline-none focus:border-gold">
                    <option value="24">24 {t.detail.months}</option>
                    <option value="36" selected>36 {t.detail.months}</option>
                    <option value="48">48 {t.detail.months}</option>
                    <option value="60">60 {t.detail.months}</option>
                  </select>
                </label>
                <div class="flex items-end justify-between border-t border-white/8 pt-4">
                  <span class="text-xs text-fog">{t.detail.perMonth}</span>
                  <span data-monthly class="font-display text-2xl text-cream"></span>
                </div>
                <p class="text-[0.62rem] leading-relaxed text-fog">{t.detail.financeNote}</p>
              </div>
            </div>
          </div>
        </aside>
      </div>

      <div class="mt-16 grid gap-10 lg:grid-cols-[1.45fr_0.55fr]">
        <div>
          <h2 class="font-display text-3xl text-cream">{t.detail.specification}</h2>
          <div class="mt-6 grid gap-px overflow-hidden border border-white/8 bg-white/8 sm:grid-cols-2">
            {specs.map((s) => (
              <div class="flex items-center justify-between bg-ink px-5 py-4">
                <span class="text-[0.72rem] tracking-[0.12em] text-fog uppercase">{s.label}</span>
                <span class="text-end text-cream">{s.value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="border border-white/8 bg-ink-850 p-7">
          <h3 class="font-display text-2xl text-cream">{t.detail.documentedReady}</h3>
          <ul class="mt-5 space-y-3 text-sm text-mist">
            {t.detail.ready.map((item: string) => (
              <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rotate-45 bg-gold"></span>{item}</li>
            ))}
          </ul>
        </div>
      </div>

      <div class="mt-24 border-t border-white/8 pt-16">
        <h2 class="font-display text-3xl text-cream">{t.detail.alsoConsider}</h2>
        <div data-grid class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedFinal.map((r, i) => <VehicleCard vehicle={r} index={i} />)}
        </div>
      </div>
    </div>
    <div class="h-24"></div>
  </main>
  <Footer />
</Base>
