---
import { process } from "../data/site";
---

<section class="relative overflow-hidden bg-ink py-24 sm:py-32 grain">
  <!-- faint backdrop -->
  <img
    src="/gallery/2.jpeg"
    alt=""
    class="absolute inset-0 h-full w-full object-cover opacity-[0.08]"
    loading="lazy"
    aria-hidden="true"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-ink via-ink/85 to-ink"></div>

  <div class="relative mx-auto max-w-[1500px] px-5 sm:px-8 lg:px-12">
    <div class="max-w-2xl">
      <p class="eyebrow flex items-center gap-3" data-reveal>
        <span class="inline-block h-px w-8 bg-gold"></span>
        How it works
      </p>
      <h2 class="display-lg mt-5 text-cream" data-reveal style="--reveal-delay:100ms">
        From enquiry to your door.
      </h2>
    </div>

    <div class="mt-16 grid gap-px overflow-hidden border border-white/8 bg-white/8 sm:grid-cols-2 lg:grid-cols-4">
      {
        process.map((p, i) => (
          <div
            class="group relative bg-ink p-8 transition-colors duration-500 hover:bg-ink-850"
            data-reveal
            style={`--reveal-delay:${i * 90}ms`}
          >
            <div class="font-display text-5xl text-gold/30 transition-colors duration-500 group-hover:text-gold">
              {p.step}
            </div>
            <h3 class="font-display mt-6 text-2xl text-cream">{p.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-mist">{p.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
