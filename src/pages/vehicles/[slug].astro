---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import VehicleCard from "../../components/VehicleCard.astro";
import {
  vehicles,
  carImages,
  fmtEUR,
  vehicleSlug,
  vehicleTitle,
  company,
  type Vehicle,
} from "../../data/site";

export function getStaticPaths() {
  return vehicles.map((v) => ({
    params: { slug: vehicleSlug(v) },
    props: { vehicle: v },
  }));
}

const { vehicle } = Astro.props as { vehicle: Vehicle };
const v = vehicle;
const title = vehicleTitle(v);
const images = carImages(v);
const imgList = images.join(",");

const related = vehicles
  .filter((x) => x.id !== v.id && x.categories.some((c) => v.categories.includes(c)))
  .slice(0, 3);
const relatedFinal = related.length ? related : vehicles.filter((x) => x.id !== v.id).slice(0, 3);

const specs: { label: string; value: string }[] = [
  { label: "Year", value: String(v.year) },
  { label: "Drivetrain", value: v.drivetrain },
  { label: "Engine", value: v.engine },
  { label: "Power", value: v.power },
  { label: "0 to 100 km/h", value: v.accel },
  { label: "Top speed", value: v.topSpeed },
  { label: "Transmission", value: v.transmission },
  { label: "Mileage", value: v.mileage },
  { label: "Exterior", value: v.colorExt },
  { label: "Interior", value: v.colorInt },
  { label: "Consumption (comb.)", value: v.consumption },
  { label: "CO₂ (comb.)", value: v.co2 },
  { label: "CO₂ class", value: v.co2class },
];
---

<Base title={`${title} · ${company.full}`} description={v.tagline}>
  <Header />
  <main class="bg-ink pt-28 sm:pt-32">
    <div class="mx-auto max-w-[1500px] px-5 sm:px-8 lg:px-12">
      <!-- Breadcrumb -->
      <a href="/collection" class="inline-flex items-center gap-2 text-[0.72rem] tracking-[0.16em] text-fog uppercase transition-colors hover:text-gold-bright">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
        Back to collection
      </a>

      <!-- Title -->
      <div class="mt-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-[0.72rem] tracking-[0.24em] text-gold uppercase">{v.brand}</p>
          <h1 class="display-lg mt-2 text-cream">
            {v.model}{v.variant && <span class="text-mist"> {v.variant}</span>}
          </h1>
          <p class="mt-3 max-w-xl text-mist">{v.tagline}</p>
        </div>
        {
          v.badge && (
            <span class="self-start border border-gold/40 px-4 py-2 text-[0.66rem] tracking-[0.18em] text-gold-bright uppercase lg:self-end">
              {v.badge}
            </span>
          )
        }
      </div>

      <!-- Gallery + summary -->
      <div class="mt-10 grid gap-10 lg:grid-cols-[1.45fr_0.55fr]">
        <!-- Gallery -->
        <div>
          <div
            data-rotate={imgList}
            class="group relative aspect-[3/2] cursor-grab touch-pan-y overflow-hidden border border-white/8 bg-ink-900 select-none"
          >
            <img data-main src={images[0]} alt={title} class="h-full w-full object-cover" transition:name={`car-${v.id}`} />
            <div class="pointer-events-none absolute bottom-3 left-3 flex items-center gap-2 border border-white/15 bg-ink/55 px-3 py-1.5 text-[0.6rem] tracking-[0.18em] text-cream/80 uppercase backdrop-blur-sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5"/></svg>
              Drag to rotate
            </div>
            <button data-open-lightbox data-images={imgList} data-index="0" aria-label="Open full gallery" class="absolute right-3 top-3 flex h-10 w-10 items-center justify-center border border-white/15 bg-ink/55 text-cream backdrop-blur-sm transition-all duration-300 hover:border-gold hover:text-gold-bright">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
            </button>
          </div>
          <div class="mt-3 grid grid-cols-5 gap-3">
            {
              images.map((src, i) => (
                <button
                  data-thumb={src}
                  class:list={[
                    "aspect-[3/2] overflow-hidden border transition-all duration-300",
                    i === 0 ? "border-gold" : "border-white/8 hover:border-gold/50",
                  ]}
                  aria-label={`Image ${i + 1}`}
                >
                  <img src={src} alt="" class="h-full w-full object-cover" loading="lazy" />
                </button>
              ))
            }
          </div>
        </div>

        <!-- Summary (sticky) -->
        <aside class="lg:sticky lg:top-28 lg:self-start">
          <div class="border border-white/8 bg-ink-850 p-7">
            <div class="font-display text-4xl text-gold-bright" data-price={v.priceNet}>{fmtEUR(v.priceNet)}</div>
            <div class="mt-1 flex flex-wrap items-center gap-x-2 text-[0.7rem] tracking-[0.12em] text-fog">
              {
                v.priceGross ? (
                  <>
                    <span>Net, export</span>
                    <span>·</span>
                    <span>Gross <span data-price={v.priceGross}>{fmtEUR(v.priceGross)}</span></span>
                  </>
                ) : (
                  <span>{v.vatNote}</span>
                )
              }
            </div>

            <div class="mt-6 grid grid-cols-2 gap-px overflow-hidden border border-white/8 bg-white/8">
              <div class="bg-ink-850 p-4"><div class="text-sm text-cream">{v.power}</div><div class="mt-1 text-[0.58rem] tracking-[0.14em] text-fog uppercase">Power</div></div>
              <div class="bg-ink-850 p-4"><div class="text-sm text-cream">{v.accel}</div><div class="mt-1 text-[0.58rem] tracking-[0.14em] text-fog uppercase">0&ndash;100 km/h</div></div>
              <div class="bg-ink-850 p-4"><div class="text-sm text-cream">{v.topSpeed}</div><div class="mt-1 text-[0.58rem] tracking-[0.14em] text-fog uppercase">Top speed</div></div>
              <div class="bg-ink-850 p-4"><div class="text-sm text-cream">{v.year}</div><div class="mt-1 text-[0.58rem] tracking-[0.14em] text-fog uppercase">Year</div></div>
            </div>

            <div class="mt-6 flex flex-col gap-3">
              <button data-enquire={v.id} data-magnetic class="btn btn-gold w-full">Enquire about this car</button>
              <div class="grid grid-cols-2 gap-3">
                <button data-fav={v.id} class="flex items-center justify-center gap-2 border border-white/12 py-3 text-[0.7rem] tracking-[0.14em] text-mist uppercase transition-all duration-300 hover:border-gold/50 hover:text-gold-bright">
                  <svg width="15" height="15" viewBox="0 0 24 24" stroke-width="1.5"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
                  Save
                </button>
                <button data-compare={v.id} class="flex items-center justify-center gap-2 border border-white/12 py-3 text-[0.7rem] tracking-[0.14em] text-mist uppercase transition-all duration-300 hover:border-gold/50 hover:text-gold-bright">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6h7v12H3zM14 6h7v12h-7z"/></svg>
                  Compare
                </button>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <a href="https://wa.me/4942180608210" target="_blank" rel="noopener" class="btn btn-ghost w-full !px-4">WhatsApp</a>
                <a href={`tel:${company.phoneHref}`} class="btn btn-ghost w-full !px-4">Call</a>
              </div>
            </div>

            <!-- Finance estimate -->
            <div class="mt-7 border-t border-white/8 pt-6">
              <div class="text-[0.68rem] tracking-[0.2em] text-fog uppercase">Finance estimate</div>
              <div class="mt-4 space-y-4" data-finance data-finance-price={v.priceNet}>
                <label class="block">
                  <div class="flex justify-between text-xs text-mist">
                    <span>Down payment</span>
                    <span data-deposit-out></span>
                  </div>
                  <input data-deposit type="range" min="0" max="60" value="20" class="mt-2 w-full accent-[var(--color-gold)]" />
                </label>
                <label class="block">
                  <span class="text-xs text-mist">Term</span>
                  <select data-term class="mt-2 w-full border border-white/12 bg-ink px-3 py-2.5 text-sm text-cream outline-none focus:border-gold">
                    <option value="24">24 months</option>
                    <option value="36" selected>36 months</option>
                    <option value="48">48 months</option>
                    <option value="60">60 months</option>
                  </select>
                </label>
                <div class="flex items-end justify-between border-t border-white/8 pt-4">
                  <span class="text-xs text-fog">Indicative / month</span>
                  <span data-monthly class="font-display text-2xl text-cream"></span>
                </div>
                <p class="text-[0.62rem] leading-relaxed text-fog">Indicative only, at 6.9% representative APR, subject to status and final terms.</p>
              </div>
            </div>
          </div>
        </aside>
      </div>

      <!-- Specification -->
      <div class="mt-16 grid gap-10 lg:grid-cols-[1.45fr_0.55fr]">
        <div>
          <h2 class="font-display text-3xl text-cream">Specification</h2>
          <div class="mt-6 grid gap-px overflow-hidden border border-white/8 bg-white/8 sm:grid-cols-2">
            {
              specs.map((s) => (
                <div class="flex items-center justify-between bg-ink px-5 py-4">
                  <span class="text-[0.72rem] tracking-[0.12em] text-fog uppercase">{s.label}</span>
                  <span class="text-right text-cream">{s.value}</span>
                </div>
              ))
            }
          </div>
        </div>
        <div class="border border-white/8 bg-ink-850 p-7">
          <h3 class="font-display text-2xl text-cream">Documented & ready</h3>
          <ul class="mt-5 space-y-3 text-sm text-mist">
            <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rotate-45 bg-gold"></span>Technically inspected and fully documented</li>
            <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rotate-45 bg-gold"></span>Worldwide enclosed delivery arranged</li>
            <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rotate-45 bg-gold"></span>Export handling and customs managed</li>
            <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rotate-45 bg-gold"></span>Bespoke individualization on request</li>
          </ul>
        </div>
      </div>

      <!-- Related -->
      <div class="mt-24 border-t border-white/8 pt-16">
        <h2 class="font-display text-3xl text-cream">You may also consider</h2>
        <div data-grid class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedFinal.map((r, i) => <VehicleCard vehicle={r} index={i} />)}
        </div>
      </div>
    </div>

    <div class="h-24"></div>
  </main>
  <Footer />
</Base>
