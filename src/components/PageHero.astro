---
interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  image?: string;
}
const { eyebrow, title, subtitle, image } = Astro.props;
---

<section class="relative overflow-hidden border-b border-white/8 bg-ink grain">
  {
    image && (
      <img src={image} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover object-center opacity-[0.16]" />
    )
  }
  <div class="absolute inset-0 bg-gradient-to-b from-ink/65 via-ink/85 to-ink"></div>
  <div class="relative mx-auto max-w-[1500px] px-5 pt-32 pb-16 sm:px-8 sm:pt-40 sm:pb-20 lg:px-12">
    <p class="eyebrow flex items-center gap-3" data-reveal>
      <span class="inline-block h-px w-8 bg-gold"></span>
      {eyebrow}
    </p>
    <h1 class="display-lg mt-5 max-w-3xl text-cream" data-reveal style="--reveal-delay:100ms">
      {title}
    </h1>
    {
      subtitle && (
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-mist" data-reveal style="--reveal-delay:180ms">
          {subtitle}
        </p>
      )
    }
  </div>
</section>
